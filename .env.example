# ----------------------------------------------------------------------------
# Career Guidance Platform — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. NEVER expose service-role key or Groq key to client.
# ----------------------------------------------------------------------------

# --- Supabase (public — safe to expose to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (server-only — NEVER expose to client) ---
# Service role bypasses RLS. Used ONLY in server routes/actions for PII writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pooled (transaction mode) connection string for migrations / direct SQL.
# Use Supabase "Connection Pooling" string (port 6543), not the direct 5432 one.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- Groq (server-only — NEVER expose to client) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Knowledge base version (stamped on every recommendation) ---
KB_VERSION=1

# --- Rate limiting (placeholder; in-memory now, Redis later) ---
# RATE_LIMIT_BACKEND=memory   # memory | redis (redis added later)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Admin dashboard ---
# HTTP Basic Auth password for /admin/* routes. Set any strong secret.
ADMIN_SECRET=your-admin-password

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
